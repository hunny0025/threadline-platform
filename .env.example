# ============================================================
# Threadline Platform - Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to GitHub.
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB Connection String
# For local: mongodb://localhost:27017/threadline
# For Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/threadline
MONGODB_URI=mongodb://localhost:27017/threadline

# JWT Secret (use a strong random string)
JWT_SECRET=your_jwt_secret_here

# Allowed Origins (comma-separated, for CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
