# ============================================================
# Threadline Platform - Environment Variables Template
# ============================================================
# HOW TO USE:
#   1. Copy: cp .env.example .env
#   2. Fill in all values below
#   3. NEVER commit the actual .env to GitHub
#
# TEAM MEMBERS: Every variable here MUST be set in your
# local .env file or the server will crash on startup.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Options: development | staging | production

# ── MongoDB ─────────────────────────────────────────────────
# Local Docker : mongodb://mongo:27017/threadline
# Atlas Staging: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/threadline
MONGODB_URI=mongodb://localhost:27017/threadline

# ── Redis ───────────────────────────────────────────────────
# Local Docker : redis://redis:6379
# Railway Redis: redis://default:<pass>@<host>:<port>
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────────
# Access token secret (short-lived 15m tokens)
JWT_SECRET=your_jwt_secret_min_32_chars_here
# Refresh token secret (long-lived 7d tokens) — MUST be different from JWT_SECRET
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_here

# ── Session ─────────────────────────────────────────────────
# Used by express-session for passport — use a strong random string
SESSION_SECRET=your_session_secret_min_32_chars_here

# ── Google OAuth ────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Local dev callback:
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
# Staging callback:
# GOOGLE_CALLBACK_URL=https://threadline-platform-production.up.railway.app/api/v1/auth/google/callback

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AWS S3 (for DB backups — optional for dev) ──────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=threadline-backups

# ── APM (New Relic) ────────────────────────────────────────
# Set license key to enable APM monitoring — run: npm install newrelic
# Leave blank to disable (no impact on startup if unset)
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=threadline-api

# ============================================================
# PLATFORM VARIABLE MAPPING
# ============================================================
#
# ▶ RAILWAY (Backend) — set all of these:
#   PORT                  ← leave blank (Railway auto-assigns)
#   NODE_ENV              ← staging
#   MONGODB_URI           ← Atlas connection string
#   REDIS_URL             ← Railway Redis plugin URL
#   JWT_SECRET            ← strong random string
#   JWT_REFRESH_SECRET    ← different strong random string
#   SESSION_SECRET        ← strong random string
#   GOOGLE_CLIENT_ID      ← from Google Cloud Console
#   GOOGLE_CLIENT_SECRET  ← from Google Cloud Console
#   GOOGLE_CALLBACK_URL   ← https://<railway-url>/api/v1/auth/google/callback
#   ALLOWED_ORIGINS       ← https://threadline-platform.vercel.app
#   AWS_ACCESS_KEY_ID     ← from AWS IAM (optional)
#   AWS_SECRET_ACCESS_KEY ← from AWS IAM (optional)
#   AWS_REGION            ← ap-south-1 (optional)
#   S3_BUCKET_NAME        ← threadline-backups (optional)
#
# ▶ VERCEL (Frontend — client/.env):
#   VITE_API_URL          ← https://threadline-platform-production.up.railway.app
#
# ▶ GITHUB SECRETS (for CI/CD workflows):
#   RAILWAY_TOKEN         ← from Railway → Account Settings → Tokens
#   VERCEL_TOKEN          ← from Vercel → Account Settings → Tokens
#   VERCEL_ORG_ID         ← from Vercel → Project Settings
#   VERCEL_PROJECT_ID     ← from Vercel → Project Settings
# ============================================================
