# ============================================================
# Threadline Platform - Environment Variables Template
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below
# 3. NEVER commit the actual .env to GitHub
# See bottom of this file for Vercel / Railway / GitHub mapping
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development            # development | staging | production

# ── MongoDB ─────────────────────────────────────────────────
# Local Docker:  mongodb://mongo:27017/threadline
# Atlas Staging: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/threadline
MONGODB_URI=mongodb://localhost:27017/threadline

# ── Redis ───────────────────────────────────────────────────
# Local Docker:  redis://redis:6379
# Railway:       redis://default:<pass>@<host>:<port>
REDIS_URL=redis://localhost:6379

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars_here
SESSION_SECRET=your_session_secret_min_32_chars_here
JWT_EXPIRES_IN=7d

# ── Google OAuth ────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AWS S3 (for DB backups) ─────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=threadline-backups

# ============================================================
# PLATFORM VARIABLE MAPPING
# ============================================================
#
# RAILWAY (Backend):
#   PORT                  → leave blank (Railway auto-assigns)
#   NODE_ENV              → staging
#   MONGODB_URI           → Atlas connection string
#   REDIS_URL             → Railway Redis plugin URL
#   JWT_SECRET            → strong random string
#   SESSION_SECRET        → strong random string
#   JWT_EXPIRES_IN        → 7d
#   GOOGLE_CLIENT_ID      → from Google Cloud Console
#   GOOGLE_CLIENT_SECRET  → from Google Cloud Console
#   GOOGLE_CALLBACK_URL   → https://<railway-url>/api/v1/auth/google/callback
#   ALLOWED_ORIGINS       → https://threadline-platform.vercel.app
#   AWS_ACCESS_KEY_ID     → from AWS IAM
#   AWS_SECRET_ACCESS_KEY → from AWS IAM
#   AWS_REGION            → ap-south-1
#   S3_BUCKET_NAME        → threadline-backups
#
# VERCEL (Frontend - client/.env):
#   VITE_API_URL          → https://<your-railway-url>.up.railway.app
#
# GITHUB SECRETS (for CI/CD):
#   RAILWAY_TOKEN         → from Railway Account Settings
#   VERCEL_TOKEN          → from Vercel Account Settings
#   VERCEL_ORG_ID         → from Vercel project settings
#   VERCEL_PROJECT_ID     → from Vercel project settings
# ============================================================
