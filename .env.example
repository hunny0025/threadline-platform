# ============================================================
# Threadline Platform - Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to GitHub.
# All these variables must also be set in Railway dashboard.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/threadline
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/threadline
MONGODB_URI=mongodb://localhost:27017/threadline

# ── JWT ──────────────────────────────────────────────────────
# Use a long random string (min 32 chars recommended)
JWT_SECRET=your_jwt_secret_here

# ── Session ──────────────────────────────────────────────────
# Used by express-session — use a strong random string
SESSION_SECRET=your_session_secret_here

# ── Google OAuth ─────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/
# Create OAuth 2.0 credentials under APIs & Services
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# For Railway staging use your Railway backend URL:
# e.g. https://threadline-platform-production.up.railway.app/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
